{
  "schemaVersion": 1,
  "id": "find-recipes-compatibility",
  "userMessage": "验证旧配方工具仍可用于兼容回放。",
  "requiredContext": ["recipes"],
  "steps": [
    {
      "type": "tool_call",
      "tool": "openallay:find_recipes",
      "arguments": {
        "outputItem": "minecraft:iron_block"
      },
      "expect": {
        "status": "success",
        "match": "contains",
        "value": {
          "outputItem": "minecraft:iron_block"
        }
      }
    },
    {
      "type": "assistant_message",
      "content": "旧工具仅作为兼容回放保留；新工作流应通过 resource_grep 发现路径，再用 resource_read 精确读取。"
    }
  ]
}
