{
  "schemaVersion": 1,
  "id": "iron-ingot-recipe",
  "userMessage": "铁锭怎么做？",
  "requiredContext": ["registries", "recipes"],
  "steps": [
    {
      "type": "tool_call",
      "tool": "openallay:resource_grep",
      "arguments": {
        "searches": [{
          "roots": ["/recipe"],
          "pattern": "minecraft:iron_ingot",
          "mode": "TOKEN",
          "fields": ["/outputs"]
        }]
      },
      "expect": {
        "status": "success",
        "match": "contains",
        "value": {
          "operation": "resource_grep"
        }
      }
    },
    {
      "type": "assistant_message",
      "content": "铁锭的制作方式应以 VFS 返回的当前配方资源及其证据为准，并从结果路径继续精确读取。"
    }
  ]
}
