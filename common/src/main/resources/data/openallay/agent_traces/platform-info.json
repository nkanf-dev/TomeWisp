{
  "schemaVersion": 1,
  "id": "platform-info",
  "userMessage": "OpenAllay 当前运行在哪个模组加载器上？",
  "requiredContext": ["observable_game_state"],
  "steps": [
    {
      "type": "tool_call",
      "tool": "openallay:resource_read",
      "arguments": {"paths": ["/game/runtime"]},
      "expect": {
        "status": "success",
        "match": "contains",
        "value": {"operation": "resource_read"}
      }
    },
    {
      "type": "assistant_message",
      "content": "平台信息来自当前请求捕获的 /game/runtime 资源。"
    }
  ]
}
