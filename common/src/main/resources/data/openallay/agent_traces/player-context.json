{
  "schemaVersion": 1,
  "id": "player-context",
  "userMessage": "结合我现在的位置和背包回答。",
  "requiredContext": ["observable_game_state"],
  "steps": [
    {
      "type": "tool_call",
      "tool": "openallay:resource_read",
      "arguments": {"paths": ["/player/profile"]},
      "expect": {
        "status": "success",
        "match": "contains",
        "value": {"operation": "resource_read"}
      }
    },
    {
      "type": "tool_call",
      "tool": "openallay:resource_glob",
      "arguments": {"patterns": [{"pattern": "/player/inventory/slot/*", "kind": "RECORD"}]},
      "expect": {
        "status": "success",
        "match": "contains",
        "value": {"operation": "resource_glob"}
      }
    },
    {
      "type": "assistant_message",
      "content": "回答将使用本次 VFS 视图中的玩家资料与背包资源，并按证据说明可见范围。"
    }
  ]
}
