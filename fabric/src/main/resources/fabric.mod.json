{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author}"
    ],
    "license": "${license}",
    "icon": "assets/openallay/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "dev.openallay.fabric.OpenAllayFabric"
        ],
        "client": [
            "dev.openallay.fabric.OpenAllayFabricClient"
        ],
        "jei_mod_plugin": [
            "dev.openallay.fabric.OpenAllayFabricJeiPlugin"
        ],
        "rei_client": [
            "dev.openallay.integration.rei.OpenAllayReiClientPlugin"
        ]
    },
    "depends": {
        "fabricloader": ">=${fabric_loader_version}",
        "fabric-command-api-v2": "*",
        "fabric-resource-loader-v1": "*",
        "fabric-networking-api-v1": "*",
        "minecraft": "~${minecraft_version}",
        "java": ">=${java_version}"
    },
    "breaks": {
        "architectury": "<=21.0.2",
        "tomewisp": "*"
    }
}
