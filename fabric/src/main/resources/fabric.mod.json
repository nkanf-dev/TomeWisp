{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author}"
    ],
    "contact": {
        "homepage": "https://github.com/nkanf-dev/TomeWisp",
        "sources": "https://github.com/nkanf-dev/TomeWisp"
    },
    "license": "${license}",
    "environment": "*",
    "entrypoints": {
        "main": [
            "dev.tomewisp.fabric.TomeWispFabric"
        ],
        "client": [
            "dev.tomewisp.fabric.TomeWispFabricClient"
        ]
    },
    "depends": {
        "fabricloader": ">=${fabric_loader_version}",
        "fabric-command-api-v2": "*",
        "fabric-resource-loader-v1": "*",
        "minecraft": "~${minecraft_version}",
        "java": ">=${java_version}"
    }
}
